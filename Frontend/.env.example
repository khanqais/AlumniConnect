# Frontend Environment Variables
# Copy this to .env and update the values

# API Base URL - use this for all API calls
VITE_API_BASE_URL=http://localhost:5000/api

# Pusher Configuration (for real-time notifications & chat)
# Get these from your Pusher Channels dashboard
VITE_PUSHER_KEY=your_pusher_key
VITE_PUSHER_CLUSTER=ap2

# For production, set this in Vercel dashboard:
# VITE_API_BASE_URL=https://your-project.vercel.app/api
